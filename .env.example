# =============================================================================
# Nifty Signals - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# TrueData API Credentials
# =============================================================================
# Get your credentials from: https://truedata.in
# Documentation: https://truedata.in/documentation
#
# After signing up, you'll receive:
# - Username (your registered email)
# - Password (provided by TrueData)

TRUEDATA_USERNAME=your_email@example.com
TRUEDATA_PASSWORD=your_truedata_password

# Optional: Custom API URLs (usually not needed)
# TRUEDATA_AUTH_URL=https://auth.truedata.in/token
# TRUEDATA_MARKET_DATA_URL=https://history.truedata.in
# TRUEDATA_CORPORATE_URL=https://corporate.truedata.in

# =============================================================================
# Claude AI Configuration (for Intelligence Layer)
# =============================================================================
# Get your API key from: https://console.anthropic.com
# The intelligence layer uses Claude for AI-powered analysis

ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Optional: Model selection
# AI_DEFAULT_MODEL=claude-3-haiku-20240307
# AI_DEEP_ANALYSIS_MODEL=claude-3-sonnet-20240229

# Optional: Enable/disable specific agents
# AI_SENTINEL_ENABLED=true
# AI_ANALYST_ENABLED=true
# AI_VALIDATOR_ENABLED=true
# AI_LEARNER_ENABLED=true
# AI_EXPLAINER_ENABLED=true

# =============================================================================
# Trading Capital Configuration
# =============================================================================
# Your trading capital in INR
# This is used for position sizing and risk calculations

TRADING_CAPITAL=1000000

# =============================================================================
# Risk Management Settings
# =============================================================================
# Override default risk limits (optional)

# MAX_PORTFOLIO_HEAT=6.0
# MAX_POSITION_PCT=15.0
# MAX_SECTOR_PCT=30.0
# MAX_POSITIONS_PER_SECTOR=3

# =============================================================================
# Data Quality Settings
# =============================================================================
# Override default data quality thresholds (optional)

# MAX_PRICE_AGE_SECONDS=900
# MAX_FII_DII_AGE_HOURS=24

# =============================================================================
# Logging & Debug Settings
# =============================================================================
# Set logging level (DEBUG, INFO, WARNING, ERROR)

LOG_LEVEL=INFO

# Enable debug mode for detailed output
# DEBUG_MODE=false

# Save all AI interactions for audit
# SAVE_AUDIT_TRAIL=true

# =============================================================================
# Notification Settings (Future Use)
# =============================================================================
# For sending trade alerts (not yet implemented)

# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# EMAIL_SMTP_SERVER=
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# ALERT_EMAIL=

# =============================================================================
# Notes
# =============================================================================
# 1. TrueData is the PRIMARY data source for reliable NSE/BSE data
#    - Without TrueData credentials, the system falls back to yfinance
#    - yfinance is free but less reliable for Indian markets
#
# 2. Claude AI is OPTIONAL but highly recommended
#    - Without an API key, the system uses rule-based analysis only
#    - With AI, you get intelligent validation and explanations
#
# 3. Risk settings in this file override config.py defaults
#    - Use these to customize for your risk tolerance
#
# 4. NEVER share your credentials or commit .env to git
# =============================================================================
